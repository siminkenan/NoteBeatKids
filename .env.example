# ── Local Development ──────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.

# PostgreSQL connection string (local, Neon, Supabase, etc.)
DATABASE_URL=postgresql://user:password@localhost:5432/notebeatkids

# Random secret for signing session cookies
# Generate a strong secret: openssl rand -hex 32
SESSION_SECRET=replace-with-a-long-random-string

# Node environment
NODE_ENV=development

# ── Frontend API URL ───────────────────────────────────────────────────────
# In development: leave empty (uses same-origin)
# In Vercel production: set to your Render backend URL
VITE_API_URL=

# ── Backend CORS (production only) ────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Example: https://your-app.vercel.app,https://www.yourdomain.com
FRONTEND_URL=

# ── Platform Notes ─────────────────────────────────────────────────────────
# Render (backend):
#   DATABASE_URL   → your Postgres connection string
#   SESSION_SECRET → generated automatically by render.yaml
#   FRONTEND_URL   → your Vercel deployment URL
#   NODE_ENV       → production (set in render.yaml)
#   PORT           → 10000 (set in render.yaml)
#
# Vercel (frontend):
#   VITE_API_URL   → https://notebeatkids.onrender.com
