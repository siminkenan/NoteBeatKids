# ── Backend (Render) Environment Variables ─────────────────────────────────
# PostgreSQL connection string (Neon, Supabase, or Render Postgres)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Random secret for signing session cookies — generate with: openssl rand -hex 32
SESSION_SECRET=replace-with-a-long-random-string

# Comma-separated list of allowed frontend origins (your Vercel URL)
FRONTEND_URL=https://your-app.vercel.app

NODE_ENV=production

# ── Frontend (Vercel) Environment Variables ────────────────────────────────
# Set this in Vercel project settings → Environment Variables
# Must point to your Render backend URL
VITE_API_URL=https://notebeatkids.onrender.com
