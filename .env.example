# Netlify'da "Site Settings > Environment Variables" bölümüne ekle

# PostgreSQL bağlantı adresi (Neon, Supabase veya başka bir dış veritabanı)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Oturum şifrelemesi için rastgele güvenli bir dize
SESSION_SECRET=guclu-rastgele-bir-sifre-buraya

# Üretim modu (Netlify'da otomatik ayarlı ama yine de ekle)
NODE_ENV=production
